# Core application
DATABASE_URL=postgres://metricsdock:metricsdock@localhost:5432/metricsdock
PG_POOL_MAX=5
BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_SECRET=replace-with-at-least-32-random-characters
ENCRYPTION_KEY=base64-32-byte-key-from-openssl-rand-base64-32
VALKEY_URL=redis://localhost:6379
SYNC_SCHEDULER_CRON=0 0 * * *
SYNC_INTERVAL_MINUTES=1440
CRON_SECRET=replace-with-a-random-secret

# Google sign-in and App Store analytics
GOOGLE_CLIENT_ID=replace-with-google-oauth-client-id
GOOGLE_CLIENT_SECRET=replace-with-google-oauth-client-secret

# Transactional email (required for password resets and invitations)
PLUNK_API_KEY=replace-with-plunk-api-key
PLUNK_FROM_EMAIL=hello@example.com
PLUNK_FROM_NAME=MetricsDock

# BullMQ Workbench authentication (required outside local development)
WORKBENCH_USERNAME=metricsdock
WORKBENCH_PASSWORD=replace-with-a-random-password
