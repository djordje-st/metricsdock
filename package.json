{
  "name": "metricsdock",
  "private": true,
  "license": "MIT",
  "packageManager": "pnpm@11.3.0",
  "engines": {
    "node": ">=22.12.0"
  },
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "dev": "vite dev --port 3000",
    "generate-routes": "tsr generate",
    "build": "vite build",
    "lint": "eslint",
    "format": "prettier --write . && eslint --fix",
    "check": "prettier --check .",
    "check:generated": "pnpm check:routes && pnpm check:migrations",
    "check:migrations": "tsx scripts/check-migration-drift.ts",
    "check:routes": "tsx scripts/check-route-tree-drift.ts",
    "typecheck": "tsc --noEmit",
    "verify:partner-events": "tsx scripts/verify-partner-event-classification.ts",
    "start": "node .output/server/index.mjs",
    "worker": "tsx --env-file-if-exists=.env --env-file-if-exists=.env.local src/worker.ts",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:destroy": "docker compose down -v",
    "email:preview": "pnpm exec email preview ./src/emails",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:pull": "drizzle-kit pull",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@better-auth/passkey": "^1.6.22",
    "@fontsource-variable/geist": "^5.2.9",
    "@fontsource-variable/inter": "^5.2.8",
    "@getworkbench/tanstack-start": "^0.9.1",
    "@logtape/logtape": "^2.2.1",
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/query-db-collection": "1.0.42",
    "@tanstack/react-db": "0.1.88",
    "@tanstack/react-form": "1.33.0",
    "@tanstack/react-query": "5.101.1",
    "@tanstack/react-router": "1.170.16",
    "@tanstack/react-router-ssr-query": "1.167.1",
    "@tanstack/react-start": "1.168.26",
    "@tanstack/react-table": "8.21.3",
    "@tanstack/router-plugin": "1.168.18",
    "better-auth": "^1.6.22",
    "bullmq": "^5.79.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "dotenv": "^17.3.1",
    "drizzle-kit": "^0.31.9",
    "drizzle-orm": "^0.45.1",
    "ioredis": "^5.11.1",
    "jsx-email": "^3.2.1",
    "lucide-react": "^0.545.0",
    "next-themes": "^0.4.6",
    "nitro": "npm:nitro-nightly@3.0.1-20260623-055145-de9708f5",
    "pg": "^8.16.3",
    "pluralize": "^8.0.0",
    "react": "^19.2.0",
    "react-day-picker": "^10.0.1",
    "react-dom": "^19.2.0",
    "recharts": "3.8.0",
    "shadcn": "^4.11.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.1.18",
    "tw-animate-css": "^1.4.0",
    "tsx": "^4.21.0",
    "unstorage": "^1.17.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@rolldown/plugin-babel": "^0.2.3",
    "@tanstack/eslint-config": "0.4.0",
    "@tanstack/router-cli": "1.167.17",
    "@types/node": "^22.10.2",
    "@types/pg": "^8.15.6",
    "@types/pluralize": "^0.0.33",
    "@types/react": "19.2.14",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^6.0.1",
    "babel-plugin-react-compiler": "^1.0.0",
    "esbuild": "^0.28.1",
    "eslint": "^10.5.0",
    "jsdom": "^28.1.0",
    "prettier": "^3.8.1",
    "typescript": "^6.0.2",
    "vite": "^8.0.0"
  }
}
